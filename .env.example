# Proveedor de IA que resume las noticias: "openai" (por defecto) o "anthropic".
LLM_PROVIDER=openai

# --- OpenAI (si LLM_PROVIDER=openai) ---
# Crea la clave en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
# (Opcional) Modelo. Por defecto gpt-4o-mini (barato). Sube a gpt-4o para más calidad.
# OPENAI_MODEL=gpt-4o-mini

# --- Claude / Anthropic (si LLM_PROVIDER=anthropic) ---
# Crea la clave en https://console.anthropic.com -> API Keys
# ANTHROPIC_API_KEY=sk-ant-...
# (Opcional) Modelo. Por defecto claude-haiku-4-5 (barato). Sube a claude-opus-4-8.
# ANTHROPIC_MODEL=claude-haiku-4-5

# --- Telegram ---
# Bot de Telegram (crea uno con @BotFather y pega el token)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstUVwxyz
# Chat donde recibir el digest (obténlo con @userinfobot)
TELEGRAM_CHAT_ID=123456789
