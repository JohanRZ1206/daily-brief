# Clave de la API de Claude (https://console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# (Opcional) Modelo a usar. Por defecto claude-opus-4-8 (el más capaz).
# Para abaratar puedes usar claude-haiku-4-5.
# ANTHROPIC_MODEL=claude-haiku-4-5

# Bot de Telegram (crea uno con @BotFather y pega el token)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstUVwxyz

# Chat donde recibir el digest (obténlo con @userinfobot)
TELEGRAM_CHAT_ID=123456789
